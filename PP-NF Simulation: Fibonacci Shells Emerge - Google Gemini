import numpy as np
import matplotlib.pyplot as plt

def simulate_bullet_cluster_nf():
    steps = 100
    # Cluster A (The 'Bullet')
    pos_a = np.array([-30.0, 0.0])
    vel_a = np.array([1.5, 0.0])
    
    # Cluster B (The 'Target')
    pos_b = np.array([10.0, 0.0])
    vel_b = np.array([-0.2, 0.0])
    
    # Track the 'Gas' (Subject to Substrate Drag/Ram Pressure)
    gas_a_pos = pos_a.copy()
    gas_b_pos = pos_b.copy()
    
    history_anchors = []
    history_gas = []
    
    for _ in range(steps):
        # 1. Anchors move freely (Low resistance NF passage)
        pos_a += vel_a * 0.5
        pos_b += vel_b * 0.5
        
        # 2. Gas experiences 'Substrate Congestion'
        # As gas clouds overlap, the NF pressure spikes, creating drag
        dist_gas = np.linalg.norm(gas_a_pos - gas_b_pos)
        drag_force = 1.0 / (dist_gas**2 + 5.0)
        
        gas_a_pos += (vel_a - drag_force * 5) * 0.5
        gas_b_pos += (vel_b + drag_force * 5) * 0.5
        
        history_anchors.append((pos_a[0], pos_b[0]))
        history_gas.append((gas_a_pos[0], gas_b_pos[0]))

    history_anchors = np.array(history_anchors)
    history_gas = np.array(history_gas)
    
    plt.figure(figsize=(12, 6))
    plt.plot(history_anchors[:,0], np.zeros(steps)+0.1, 'bo', label="Lensing Centers (PP Anchors/Refractive Lens)")
    plt.plot(history_gas[:,0], np.zeros(steps)-0.1, 'rx', label="Baryonic Gas (Substrate Congestion/Drag)")
    plt.axvline(x=0, color='k', linestyle='--', alpha=0.3, label="Collision Point")
    
    plt.title("PP-NF Simulation: Bullet Cluster Lensing vs. Gas Offset")
    plt.xlabel("Position")
    plt.yticks([])
    plt.legend()
    plt.show()

